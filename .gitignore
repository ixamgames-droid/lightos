!shows/demo_*.lshow
# Archiv alter Shows (User-Daten, nicht versioniert)
shows/_archiv/
# Verirrte Show-Dateien im Repo-Root (Scratch — Shows gehoeren nach shows/)
/*.lshow

# Eigene Fixture-Profile
fixtures/custom/*

